/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://clerk.studieskit.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://api.fontshare.com; font-src 'self' https://fonts.gstatic.com https://cdn.fontshare.com; connect-src 'self' https://*.clerk.dev https://*.clerk.accounts.dev https://clerk.studieskit.com https://api.stripe.com; img-src 'self' data: https://img.clerk.com; frame-src https://js.stripe.com; frame-ancestors 'none'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()
